{
  "name": "GWGStuttgartServer",
  "version": "1.0.0",
  "description": "Backend Server GWG Stuttgart",
  "main": "index.js",
  "repository": "git@github.com:Mieterapp/GWGStuttgartServer.git",
  "author": "Philipp Litzenberger <philipp@litzenberger.engineering>",
  "private": true,
  "scripts": {
    "START >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>": "",
    "start": "yarn db:migrate; docker-compose up",
    "stop": "docker-compose stop",
    "start:srv-admin": "yarn db:migrate; yarn start srv-admin",
    "start:srv-db": "yarn start srv-db",
    "TEST  >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>": "",
    "test": "yarn dc:run srv-admin pytest src",
    "test:local": "cd srv-admin; export DATABASE_HOST=localhost; ./venv/bin/pytest -s",
    "test-specific": "docker-compose exec srv-admin ./manage.py test",
    "pretest": "yarn db:start",
    "posttest": "yarn db:stop",
    "BUILD >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>": "",
    "build": "docker-compose build",
    "DATABASE >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>": "",
    "db:start": "docker-compose up -d srv-db",
    "db:stop": "docker-compose stop srv-db",
    "db:reset": "yarn stop srv-db; docker-compose rm srv-db",
    "db:migrate": "docker-compose run srv-admin ./manage.py migrate",
    "db:sync": "docker-compose run srv-admin ./manage.py migrate --run-syncdb",
    "db:fixtures": "docker-compose run srv-admin ./manage.py loaddata",
    "db:makemigrations": "docker-compose run srv-admin ./manage.py makemigrations",
    "db:createsuperuser": "docker-compose run srv-admin ./manage.py createsuperuser",
    "db:import-issues": "docker-compose run srv-admin ./manage.py import_issues",
    "DOCKER-COMPOSE >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>": "",
    "dc": "docker-compose $(echo ${DOCKER_COMPOSE_CONFIG_FILE:-\"-f docker-compose.yml\"})",
    "dc:up": "docker-compose up",
    "dc:run": "docker-compose run",
    "dc:stop": "docker-compose stop",
    "dc:exec": "docker-compose exec"
  }
}
